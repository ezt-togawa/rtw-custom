<odoo>
    <data>
        <record id="view_mrp_production_list_rtw" model="ir.ui.view">
            <field name="name">rtw mrp production list</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_tree_view" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button string="ラベル位置設定" name="create_location_item_excel_prod_label"
                        type="object"
                        class="oe_highlight" />
                </xpath>
            </field>
        </record>

        <record id="view_mrp_production_sale_list_rtw" model="ir.ui.view">
            <field name="name">rtw sale to mrp production list</field>
            <field name="model">sale.to.mrp.list</field>
            <field name="inherit_id" ref="rtw_mrp_custom.sale_to_mrp_list_view_tree" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button string="ラベル位置設定" name="create_location_item_excel_prod_label"
                        type="object"
                        class="oe_highlight" />
                </xpath>
            </field>
        </record>

        <record id="view_stock_move_list_rtw" model="ir.ui.view">
            <field name="name">rtw stock move</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="rtw_stock_move_line.stock_move_list" />
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <header>
                        <button string="ラベル位置設定"
                            name="create_location_item_excel_prod_label"
                            type="object"
                            class="oe_highlight" />
                    </header>
                </xpath>
            </field>
        </record>
        <record id="view_move_form_rtw" model="ir.ui.view">
            <field name="name">rtw stock move form</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_form" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                        <button string="ラベル位置設定"
                            name="create_location_item_excel_prod_label"
                            type="object"
                            class="oe_highlight" />
                </xpath>
            </field>
        </record>
        <record id="view_picking_form_rtw" model="ir.ui.view">
            <field name="name">rtw view picking form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button string="ラベル位置設定"
                            name="create_location_item_excel_prod_label"
                            type="object"
                            class="oe_highlight"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>