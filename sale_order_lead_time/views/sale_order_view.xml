<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_view_order_lead_time_form" model="ir.ui.view">
            <field name="name">Sale Order RTW</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_order_rtw.sale_view_order_rtw_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='workday_id']" position="after">
                    <field name="leadtime" force_save="1" readonly="1" />
                </xpath>
                <xpath expr="//field[@name='leadtime']" position="after">
                    <label for="scheduled_order_date" />
                    <div class="o_row">
                        <field name="scheduled_order_date" nolabel="1" />
                        <button name="update_leadtime"
                            class="btn-link" icon="fa-refresh"
                            confirm="発注予定日に基づいてすべての明細情報の製造完予定日が更新されます"
                            string="再計算して反映" type="object"
                        />
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
